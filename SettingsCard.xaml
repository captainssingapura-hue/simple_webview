<UserControl
    x:Class="WinUI3TabsApp.SettingsCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="8"
        Padding="16"
        Margin="0,2">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Icon -->
            <Border
                Grid.Column="0"
                Width="36" Height="36"
                Background="{ThemeResource AccentFillColorDefaultBrush}"
                CornerRadius="8"
                Margin="0,0,14,0">
                <FontIcon
                    x:Name="IconElement"
                    Glyph="&#xE713;"
                    FontSize="16"
                    Foreground="White"/>
            </Border>

            <!-- Title + Description -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                <TextBlock x:Name="TitleText" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <TextBlock x:Name="DescriptionText" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6" TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Action -->
            <ContentPresenter
                Grid.Column="2"
                x:Name="ActionPresenter"
                VerticalAlignment="Center"
                Margin="12,0,0,0"/>
        </Grid>
    </Border>
</UserControl>
